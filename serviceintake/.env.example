# Copy to .env.local and fill in. In Vercel, add these as Environment Variables.
POWER_AUTOMATE_WEBHOOK_URL=""

# Vercel Blob store token, used to issue client upload tokens for photos.
# Vercel injects this automatically once a Blob store is linked to the project;
# only needed here for local dev.
BLOB_READ_WRITE_TOKEN=""

# --- Neon Postgres (durable intake records) ---
# Shared contact-oracle Neon project; intake tables live in the `intake` schema.
# Server-side only. In Vercel, set as an Environment Variable.
DATABASE_URL=

# --- Twilio SMS alerts (internal team notification) ---
# Same Twilio account as odysseymovie. Server-side only.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Comma-separated list of numbers to text on each submission (E.164, e.g. +15874364125).
SERVICE_SMS_RECIPIENTS=

# Base URL used to build the request-detail link (/r/<id>) in the SMS.
# Prod: https://innovadevelopments.vercel.app
NEXT_PUBLIC_SITE_URL=
